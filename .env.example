# Crypto Twitter Pipeline Environment

# Xquik API Key - Get at https://xquik.com
XQUIK_API_KEY=your_xquik_api_key_here

# MiniMax API Key - Get at https://platform.minimax.io
MINIMAX_API_KEY=your_minimax_api_key_here

# Optional: Telegram Bot Token (for Hermes integration)
TELEGRAM_BOT_TOKEN=

# Optional: MiniMax Model (defaults to MiniMax-M2.7)
MINIMAX_MODEL=MiniMax-M2.7